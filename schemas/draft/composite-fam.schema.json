{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zeroroomlab.example/ibd/season-0/composite-fam.schema.json",
  "title": "IBD Composite FAM Season 0 Draft",
  "type": "object",
  "required": ["schema_version", "composite_fam_id", "query_ref", "ψ", "∇φ", "λ", "Q", "source_clusters", "assembly_graph", "provenance"],
  "properties": {
    "schema_version": {"const": "ibd.composite-fam/0.1.0-draft"},
    "composite_fam_id": {"type": "string", "minLength": 1},
    "query_ref": {"type": "string", "minLength": 1},
    "ψ": {"type": "object"},
    "∇φ": {"type": "object"},
    "λ": {"type": "object"},
    "Q": {"type": "object"},
    "source_clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cluster_ref", "database_ref", "content_hash"],
        "properties": {
          "cluster_ref": {"type": "string"},
          "database_ref": {"type": "string", "pattern": "^ibd://"},
          "content_hash": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "mapping_fam_refs": {"type": "array", "items": {"type": "string"}},
    "assembly_graph": {"type": "array", "items": {"type": "object"}},
    "evidence_bindings": {"type": "array", "items": {"type": "string"}},
    "last_order_refs": {"type": "array", "items": {"type": "string"}},
    "unresolved_slots": {"type": "array", "items": {"type": "object"}},
    "source_mutation": {"const": false},
    "provenance": {"type": "object"}
  },
  "additionalProperties": false
}
